<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🎀 소비 코치</title>
<style>
    body {
        font-family: 'Arial', sans-serif;
        background: #FFF5F7;
        margin: 0;
        padding: 20px;
    }

    .container {
        max-width: 600px;
        margin: auto;
        background: white;
        padding: 20px;
        border-radius: 20px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    h1 {
        text-align: center;
        color: #FF8FA3;
    }

    .input-box {
        margin: 15px 0;
    }

    input[type="number"] {
        width: 100%;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #ddd;
    }

    .slider-box {
        margin: 15px 0;
    }

    label {
        display: block;
        margin-bottom: 5px;
    }

    input[type="range"] {
        width: 100%;
    }

    .result {
        margin-top: 20px;
        padding: 15px;
        background: #F0FFF5;
        border-radius: 15px;
    }

    .category {
        margin-bottom: 10px;
    }
</style>
</head>
<body>

<div class="container">
    <h1>💸 나의 소비 코치</h1>

    <div class="input-box">
        <label>월 예산 입력 (원)</label>
        <input type="number" id="budget" placeholder="예: 800000">
    </div>

    <div class="slider-box">
        <label>🍙 식비: <span id="foodPercent">30</span>%</label>
        <input type="range" min="0" max="100" value="30" id="food">
    </div>

    <div class="slider-box">
        <label>☕ 카페: <span id="cafePercent">20</span>%</label>
        <input type="range" min="0" max="100" value="20" id="cafe">
    </div>

    <div class="slider-box">
        <label>🛍 쇼핑: <span id="shopPercent">20</span>%</label>
        <input type="range" min="0" max="100" value="20" id="shop">
    </div>

    <div class="slider-box">
        <label>🚇 교통: <span id="transportPercent">15</span>%</label>
        <input type="range" min="0" max="100" value="15" id="transport">
    </div>

    <div class="slider-box">
        <label>🎀 기타: <span id="etcPercent">15</span>%</label>
        <input type="range" min="0" max="100" value="15" id="etc">
    </div>

    <button onclick="calculate()" style="width:100%; padding:10px; border:none; border-radius:10px; background:#FFB6C1; color:white; font-size:16px;">계산하기</button>

    <div class="result" id="result"></div>
</div>

<script>
    const sliders = ['food','cafe','shop','transport','etc'];

    sliders.forEach(id => {
        document.getElementById(id).addEventListener('input', function() {
            document.getElementById(id+'Percent').innerText = this.value;
        });
    });

    function calculate() {
        const budget = document.getElementById('budget').value;
        if (!budget) return alert('예산을 입력해주세요!');

        let totalPercent = 0;
        sliders.forEach(id => {
            totalPercent += parseInt(document.getElementById(id).value);
        });

        if (totalPercent !== 100) {
            alert('비율의 합이 100%가 되어야 합니다!');
            return;
        }

        let resultHTML = '';

        sliders.forEach(id => {
            const percent = document.getElementById(id).value;
            const amount = budget * percent / 100;
            const daily = amount / 30;

            resultHTML += `
                <div class="category">
                    <b>${id}</b>: ${Math.round(amount)}원 (하루 ${Math.round(daily)}원)
                </div>
            `;
        });

        document.getElementById('result').innerHTML = resultHTML;
    }
</script>

</body>
</html>